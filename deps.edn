{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace (same shape as
 ;; gftd-talent-actor / cloud-itonami deps.edn).
 ;;
 ;; kotoba-lang/org-oasis-open-xmile is the real simulation engine underneath
 ;; the SD-LLM advisor's proposals and the ScenarioGovernor's structural +
 ;; plausibility checks — pinned by :git/sha at its current main HEAD
 ;; (no sibling checkout needed; a plain git dependency, resolved over
 ;; network like org-oasis-open-xmile's own dsl-core dep).
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../com-junkawasaki/langgraph-clj"}
        io.github.kotoba-lang/org-oasis-open-xmile
        {:git/sha "3930c70b52611dee6aa75910b02010e1cb657c6f"}
        org.clojure/data.json {:mvn/version "2.5.1"}} ; yosoku.deploy real-LLM json (same as tashikame/kouhou)
 :aliases
 {;; offline workspace dev — pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../com-junkawasaki/langchain-clj"}}}
  ;; clojure -M:dev:run  → drive the demo scenarios through one ScenarioActor
  :run {:main-opts ["-m" "yosoku.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis — clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
